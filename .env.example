# SmartCampusAI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it is in .gitignore)

# ── JWT Secret (generate a random 32+ char string) ─────────────────────────
JWT_SECRET=change-me-to-any-random-32-char-string

# ── Google OAuth (from Google Cloud Console) ────────────────────────────────
# console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_CLIENT_SECRET

# ── Gmail SMTP (for sending OTP reset emails) ───────────────────────────────
# myaccount.google.com/security → 2-Step Verification → App Passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Admin account (this email gets Admin role automatically) ────────────────
ADMIN_EMAIL=admin@gmail.com

# ── Auth server port (default: 3002) ───────────────────────────────────────
AUTH_PORT=3002

# ── Groq AI API key (existing) ─────────────────────────────────────────────
GROQ_API_KEY=your-existing-groq-api-key
