{
  "name": "smartcampusai",
  "main": "node_modules/expo/AppEntry.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "lint": "expo lint",
    "test:e2e": "mocha selenium-tests/tests/*.test.cjs --timeout 90000 --reporter spec --exit",
    "test:e2e:ci": "mocha selenium-tests/tests/*.test.cjs --timeout 90000 --reporter json --reporter-option output=\"Test Results/mocha-results.json\" --exit",
    "test:login": "mocha selenium-tests/tests/login.test.cjs --timeout 90000 --exit",
    "generate:report": "node selenium-tests/scripts/generate-reports.cjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "express": "^5.2.1",
    "firebase": "^12.14.0",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "autocannon": "^8.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2",
    "mocha": "^11.7.6",
    "exceljs": "^4.4.0",
    "selenium-webdriver": "^4.45.0"
  },
  "private": true,
  "overrides": {
    "js-yaml": "4.2.0",
    "postcss": "8.5.15"
  }
}
